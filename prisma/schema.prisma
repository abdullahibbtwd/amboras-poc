generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model ThemeEmbedding {
  id        Int    @id @default(autoincrement())
  filePath  String
  chunkText String
  embedding Unsupported("vector(768)")
}